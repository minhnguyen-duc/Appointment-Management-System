@* KAN-11 AC1: Password form cho existing patient *@

<div class="form-title">Nhập mật khẩu</div>
<div class="form-sub">
    Số điện thoại <strong>@PhoneDisplay</strong> đã có tài khoản.<br/>
    Nhập mật khẩu để đăng nhập.
</div>

<div class="input-group" style="position:relative">
    <input class="input-field"
           type="@(_showPw ? "text" : "password")"
           placeholder="Mật khẩu"
           autocomplete="current-password"
           @bind="_password"
           @bind:event="oninput"
           @onkeydown="OnKeyDown"
           disabled="@IsLoading" />
    <button type="button"
            class="pw-toggle"
            @onclick="() => _showPw = !_showPw"
            tabindex="-1">
        @if (_showPw)
        {
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" y1="2" x2="22" y2="22"/></svg>
        }
        else
        {
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
        }
    </button>
</div>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="inline-error">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
        <span>@ErrorMessage</span>
    </div>
}

@if (IsLocked)
{
    <div class="lock-banner">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Tài khoản tạm khóa đến @(LockedUntil?.ToLocalTime().ToString("HH:mm dd/MM"))
    </div>
}

<button class="btn-primary"
        @onclick="Submit"
        disabled="@(IsLoading || IsLocked || string.IsNullOrWhiteSpace(_password))">
    @if (IsLoading)
    {
        <span class="spinner"></span>
    }
    Đăng nhập
</button>

<div style="text-align:center;margin-top:12px">
    <button class="forgot-pw-btn" @onclick="OnForgotPassword" tabindex="0">
        Quên mật khẩu? Dùng OTP
    </button>
</div>

@code {
    [Parameter] public string PhoneNumber { get; set; } = "";
    [Parameter] public EventCallback<string> OnSubmit { get; set; }
    [Parameter] public EventCallback OnForgotPassword { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool IsLocked { get; set; }
    [Parameter] public DateTime? LockedUntil { get; set; }

    private string _password = "";
    private bool _showPw;
    private string _errorMessage = "";

    public string ErrorMessage { get => _errorMessage; }
    public void SetError(string msg) { _errorMessage = msg; StateHasChanged(); }
    public void ClearError() { _errorMessage = ""; StateHasChanged(); }

    private string PhoneDisplay => PhoneNumber.Length > 3
        ? PhoneNumber[..3] + "****" + PhoneNumber[^3..]
        : PhoneNumber;

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_password) || IsLocked) return;
        await OnSubmit.InvokeAsync(_password);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }
}
