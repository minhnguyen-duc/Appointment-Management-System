@using Domain.ValueObjects

<div class="form-title">Nhập số điện thoại</div>
<div class="form-sub">Hệ thống sẽ gửi mã OTP 6 chữ số qua SMS để xác thực danh tính của bạn.</div>

<div class="input-group">
    <div class="input-prefix">
        🇻🇳 +84
    </div>
    <input class="input-field"
           type="tel"
           placeholder="901 234 567"
           maxlength="10"
           inputmode="numeric"
           @bind="_phone"
           @bind:event="oninput"
           @onkeydown="OnKeyDown"
           @onblur="OnBlur"
           disabled="@IsLoading" />
</div>

<div style="font-size:12px;color:var(--txt3);margin-bottom:20px;line-height:1.6;">
    Bằng cách tiếp tục, bạn đồng ý với
    <a href="#" style="color:var(--blue-txt);text-decoration:none;">Điều khoản dịch vụ</a>
    và
    <a href="#" style="color:var(--blue-txt);text-decoration:none;">Chính sách bảo mật</a>
    của MediCare.
</div>

<button class="btn-primary"
        @onclick="Submit"
        disabled="@(IsLoading || string.IsNullOrWhiteSpace(_phone) || (_touched && !_isValid))">
    Tiếp tục
</button>

@code {
    [Parameter] public EventCallback<string> OnSubmit { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    private string _phone = "";
    private bool _touched;
    private bool _isValid;

    private void Validate() => _isValid = VietnamPhoneNumber.IsValid(_phone);

    private void OnBlur()
    {
        if (!string.IsNullOrWhiteSpace(_phone)) { _touched = true; Validate(); }
    }

    private async Task Submit()
    {
        _touched = true;
        Validate();
        if (!_isValid) return;
        await OnSubmit.InvokeAsync(_phone.Trim());
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }
}
