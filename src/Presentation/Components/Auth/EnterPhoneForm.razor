@using Domain.ValueObjects

<div class="form-title">Nhập số điện thoại</div>
<div class="form-sub">Hệ thống sẽ gửi mã OTP 6 chữ số qua SMS để xác thực danh tính của bạn.</div>

<div class="input-group @(_touched && !_isValid ? "input-error" : "")">
    <div class="input-prefix">
        🇻🇳 +84
    </div>
    <input class="input-field"
           type="tel"
           placeholder="901 234 567"
           maxlength="11"
           inputmode="numeric"
           @bind="_phone"
           @bind:event="oninput"
           @onkeydown="OnKeyDown"
           @onblur="OnBlur"
           disabled="@IsLoading" />
    @if (!string.IsNullOrWhiteSpace(_phone))
    {
        <button type="button" class="input-clear" @onclick="ClearPhone" tabindex="-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
        </button>
    }
</div>

@if (_touched && !_isValid && !string.IsNullOrWhiteSpace(_phone))
{
    <div class="validation-msg">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
        Vui lòng nhập số điện thoại Việt Nam hợp lệ (03x / 05x / 07x / 08x / 09x)
    </div>
}
@if (_touched && !_isValid && string.IsNullOrWhiteSpace(_phone))
{
    <div class="validation-msg">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
        Vui lòng nhập số điện thoại
    </div>
}

<div style="font-size:12px;color:var(--txt3);margin-bottom:20px;line-height:1.6;">
    Bằng cách tiếp tục, bạn đồng ý với
    <a href="#" style="color:var(--blue-txt);text-decoration:none;">Điều khoản dịch vụ</a>
    và
    <a href="#" style="color:var(--blue-txt);text-decoration:none;">Chính sách bảo mật</a>
    của MediCare.
</div>

<button class="btn-primary"
        @onclick="Submit"
        disabled="@(IsLoading || string.IsNullOrWhiteSpace(_phone) || (_touched && !_isValid))">
    Tiếp tục
</button>

@code {
    [Parameter] public EventCallback<string> OnSubmit { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    private string _phone = "";
    private bool _touched;
    private bool _isValid;

    // Validate on every keystroke — show error immediately after user types
    private void Validate() => _isValid = VietnamPhoneNumber.IsValid(_phone);

    private void OnBlur()
    {
        if (!string.IsNullOrWhiteSpace(_phone))
        {
            _touched = true;
            Validate();
        }
    }

    private void ClearPhone()
    {
        _phone = "";
        _touched = false;
        _isValid = false;
    }

    private async Task Submit()
    {
        _touched = true;
        Validate();
        if (!_isValid) return;
        await OnSubmit.InvokeAsync(_phone.Trim());
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }
}
