@* KAN-11 AC1: Set password form cho new patient sau khi OTP verify *@

<div class="form-title">Tạo mật khẩu</div>
<div class="form-sub">
    Mã OTP đã xác thực. Hãy tạo mật khẩu cho tài khoản mới của bạn.
</div>

<div class="input-group" style="position:relative;margin-bottom:12px">
    <input class="input-field"
           type="@(_showPw ? "text" : "password")"
           placeholder="Mật khẩu (ít nhất 6 ký tự)"
           autocomplete="new-password"
           @bind="_password"
           @bind:event="oninput"
           @onkeydown="OnKeyDown"
           disabled="@IsLoading" />
    <button type="button" class="pw-toggle" @onclick="() => _showPw = !_showPw" tabindex="-1">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
    </button>
</div>

<div class="input-group" style="position:relative;margin-bottom:12px">
    <input class="input-field"
           type="@(_showPw ? "text" : "password")"
           placeholder="Xác nhận mật khẩu"
           autocomplete="new-password"
           @bind="_confirm"
           @bind:event="oninput"
           @onkeydown="OnKeyDown"
           disabled="@IsLoading" />
</div>

@if (_touched && !string.IsNullOrWhiteSpace(_confirm) && _password != _confirm)
{
    <div class="inline-error">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
        Mật khẩu xác nhận không khớp.
    </div>
}

@if (_touched && !string.IsNullOrWhiteSpace(_password) && _password.Length < 6)
{
    <div class="inline-error">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
        Mật khẩu phải có ít nhất 6 ký tự.
    </div>
}

<button class="btn-primary"
        @onclick="Submit"
        disabled="@(IsLoading || !IsValid)">
    @if (IsLoading)
    {
        <span class="spinner"></span>
    }
    Tạo tài khoản
</button>

@code {
    [Parameter] public EventCallback<string> OnSubmit { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    private string _password = "";
    private string _confirm  = "";
    private bool _showPw;
    private bool _touched;

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_password) &&
        _password.Length >= 6 &&
        _password == _confirm;

    private async Task Submit()
    {
        _touched = true;
        if (!IsValid) return;
        await OnSubmit.InvokeAsync(_password);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Submit();
    }
}
