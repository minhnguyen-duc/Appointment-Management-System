@implements IDisposable

@if (_seconds > 0)
{
    <span class="text-muted small">Gửi lại sau <strong>@_seconds</strong>s</span>
}
else
{
    <button class="btn btn-link btn-sm p-0" @onclick="Resend">Gửi lại mã OTP</button>
}

@code {
    [Parameter] public EventCallback OnResend { get; set; }

    private int _seconds = 60;
    private Timer? _timer;

    protected override void OnInitialized() => StartCountdown();

    private void StartCountdown()
    {
        _seconds = 60;
        _timer = new Timer(_ => { if (--_seconds <= 0) _timer?.Dispose(); InvokeAsync(StateHasChanged); }, null, 1000, 1000);
    }

    private async Task Resend() { await OnResend.InvokeAsync(); StartCountdown(); }
    public void Dispose() => _timer?.Dispose();
}
