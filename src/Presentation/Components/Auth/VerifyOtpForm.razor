@inject IJSRuntime JS

@* AC3 - KAN-11: Hiển thị số lần gửi lại còn lại và trạng thái khoá *@
@* AC4 - KAN-11: Gọi OnSubmit với 6 chữ số OTP *@

<div class="auth-form">
    <h5>Nhập mã xác thực</h5>
    <p class="text-muted small">
        Mã OTP đã được gửi đến <strong>@PhoneNumber</strong> qua SMS/Zalo.
        <br />Mã có hiệu lực trong <strong>2 phút</strong>.
    </p>

    @if (IsLocked)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2">
            <i class="bi bi-lock-fill fs-5"></i>
            <div>
                <strong>Tài khoản tạm thời bị khoá</strong><br />
                <small>Bạn đã gửi lại OTP quá @ResendMax lần. Vui lòng thử lại sau khi hết thời gian khoá.</small>
            </div>
        </div>
    }

    <div class="otp-inputs mb-2 @(IsLocked ? "opacity-50 pe-none" : "")">
        @for (int i = 0; i < 6; i++)
        {
            var idx = i;
            <input type="text"
                   maxlength="1"
                   inputmode="numeric"
                   pattern="[0-9]*"
                   class="otp-box form-control @(_hasError ? "is-invalid" : "")"
                   @ref="_inputs[idx]"
                   @oninput="e => OnInput(e, idx)"
                   @onkeydown="e => OnKeyDown(e, idx)"
                   @onpaste="e => OnPaste(e)"
                   disabled="@(IsLoading || IsLocked)" />
        }
    </div>

    @if (_hasError)
    {
        <div class="text-danger small mb-2">
            <i class="bi bi-exclamation-triangle me-1"></i>@_errorMsg
        </div>
    }

    <button class="btn btn-primary w-100 btn-lg mb-2"
            @onclick="Submit"
            disabled="@(IsLoading || _otp.Replace(" ","").Length < 6 || IsLocked)">
        @if (IsLoading)
        {
            <span class="spinner-border spinner-border-sm me-2"></span>
        }
        <i class="bi bi-check-circle me-1"></i> Xác nhận
    </button>

    <div class="text-center">
        <CountdownResend OnResend="OnResend"
                         ResendUsed="@ResendUsed"
                         ResendMax="@ResendMax"
                         IsLocked="@IsLocked"
                         LockedUntil="@LockedUntil" />
    </div>
</div>

@code {
    [Parameter] public string PhoneNumber { get; set; } = "";
    [Parameter] public EventCallback<string> OnSubmit { get; set; }
    [Parameter] public EventCallback OnResend { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public int ResendUsed { get; set; }
    [Parameter] public int ResendMax { get; set; } = 3;
    [Parameter] public bool IsLocked { get; set; }
    [Parameter] public DateTime? LockedUntil { get; set; }

    private readonly ElementReference[] _inputs = new ElementReference[6];
    private readonly char[] _digits = new char[6];
    private string _otp => new string(_digits).Trim('\0');
    private bool _hasError;
    private string _errorMsg = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await JS.InvokeVoidAsync("eval", "document.querySelector('.otp-box')?.focus()");
    }

    private void OnInput(ChangeEventArgs e, int idx)
    {
        _hasError = false;
        var val = e.Value?.ToString()?.Trim() ?? "";
        if (val.Length == 0) { _digits[idx] = '\0'; return; }

        // Handle paste of full code into first box
        if (val.Length == 6 && idx == 0)
        {
            for (int i = 0; i < 6; i++) _digits[i] = char.IsDigit(val[i]) ? val[i] : '\0';
            StateHasChanged();
            return;
        }

        var ch = val[^1];
        if (!char.IsDigit(ch)) return;
        _digits[idx] = ch;

        // Auto-advance
        if (idx < 5) _ = FocusAsync(idx + 1);

        // Auto-submit when all 6 filled
        if (_digits.All(c => c != '\0')) _ = Submit();
    }

    private async Task OnKeyDown(KeyboardEventArgs e, int idx)
    {
        if (e.Key == "Backspace" && _digits[idx] == '\0' && idx > 0)
        {
            _digits[idx - 1] = '\0';
            await FocusAsync(idx - 1);
        }
        else if (e.Key == "Enter" && _otp.Length == 6)
        {
            await Submit();
        }
    }

    private void OnPaste(ClipboardEventArgs e)
    {
        // JS interop handles paste; Blazor ClipboardEventArgs doesn't expose data
        // Actual paste is handled via oninput when text arrives in the box
    }

    private async Task FocusAsync(int idx)
    {
        try { await JS.InvokeVoidAsync("eval", $"document.getElementById('otp-box-{idx}')?.focus()"); }
        catch { /* ignore */ }
    }

    private async Task Submit()
    {
        var code = new string(_digits);
        if (code.Length < 6 || code.Any(c => !char.IsDigit(c)))
        {
            _hasError = true; _errorMsg = "Vui lòng nhập đủ 6 chữ số.";
            return;
        }
        await OnSubmit.InvokeAsync(code);
    }

    // Called from Login.razor after failed verify
    public void SetError(string msg) { _hasError = true; _errorMsg = msg; StateHasChanged(); }
    public void ClearError() { _hasError = false; Array.Clear(_digits, 0, 6); StateHasChanged(); }
}
