@implements IDisposable

@if (_visible)
{
    <div class="toast-wrap @(_type)" @onclick="Hide">
        <div class="toast-icon-box">
            @if (_type == "info" || _type == "success")
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="m9 12 2 2 4-4"/>
                </svg>
            }
            else
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 8v4m0 4h.01"/>
                </svg>
            }
        </div>
        <span class="toast-msg">@Message</span>
        <button class="toast-close" @onclick:stopPropagation="true" @onclick="Hide">×</button>
    </div>
}

<style>
.toast-wrap {
    position: fixed; top: 24px; right: 24px; z-index: 9999;
    display: flex; align-items: center; gap: 10px;
    padding: 13px 18px;
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0,0,0,.16);
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 14px; font-weight: 500;
    animation: toastIn .3s cubic-bezier(.16,1,.3,1);
    max-width: 340px; cursor: pointer;
}
/* Blue — matches screenshot exactly */
.toast-wrap.info    { background: #1A9CE0; color: #fff; }
.toast-wrap.success { background: #1A9CE0; color: #fff; }
.toast-wrap.error   { background: #DC2626; color: #fff; }
.toast-wrap.warning { background: #D97706; color: #fff; }
.toast-icon-box { display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.toast-msg { flex: 1; line-height: 1.4; }
.toast-close {
    background: none; border: none;
    color: rgba(255,255,255,.75); font-size: 20px;
    cursor: pointer; padding: 0 0 0 6px; line-height: 1;
    transition: color .15s;
}
.toast-close:hover { color: #fff; }
@@keyframes toastIn {
    from { opacity: 0; transform: translateX(20px) scale(.97); }
    to   { opacity: 1; transform: translateX(0) scale(1); }
}
</style>

@code {
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public string Type    { get; set; } = "info";

    private bool   _visible;
    private string _type = "info";
    private System.Threading.Timer? _timer;

    public void Show(string message, string type = "info", int durationMs = 3500)
    {
        Message  = message;
        _type    = type;
        _visible = true;
        StateHasChanged();

        _timer?.Dispose();
        _timer = new System.Threading.Timer(_ => InvokeAsync(Hide), null, durationMs, Timeout.Infinite);
    }

    private void Hide() { _visible = false; StateHasChanged(); }
    public void Dispose() => _timer?.Dispose();
}
