<div class="filter-bar d-flex flex-wrap gap-2">
    <input type="search" class="form-control w-auto" placeholder="Tìm bệnh nhân, bác sĩ..."
           @bind="_model.Keyword" @bind:event="oninput" @oninput="Notify" />
    <input type="date" class="form-control w-auto"
           @bind="_model.Date" @bind:event="onchange" @onchange="Notify" />
    <select class="form-select w-auto" @bind="_model.Status" @bind:after="Notify">
        <option value="">Tất cả trạng thái</option>
        <option value="Pending">Chờ xác nhận</option>
        <option value="Confirmed">Đã xác nhận</option>
        <option value="Cancelled">Đã huỷ</option>
        <option value="Completed">Hoàn thành</option>
    </select>
</div>

@code {
    [Parameter] public AppointmentFilterModel Filter { get; set; } = new();
    [Parameter] public EventCallback<AppointmentFilterModel> OnChanged { get; set; }

    private AppointmentFilterModel _model = new();
    protected override void OnParametersSet() => _model = Filter;

    private async Task Notify() => await OnChanged.InvokeAsync(_model);
}
