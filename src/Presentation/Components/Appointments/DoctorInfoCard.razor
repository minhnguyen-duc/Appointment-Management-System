<div class="card @Class">
    <div class="card-header fw-semibold">Bác sĩ phụ trách</div>
    <div class="card-body">
        <div class="d-flex align-items-center gap-3">
            <div class="avatar-circle bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center"
                 style="width:48px;height:48px;font-size:18px;">
                <i class="bi bi-person-badge"></i>
            </div>
            <div>
                <div class="fw-semibold">@DoctorName</div>
                <div class="text-muted small">@Specialization</div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? DoctorName { get; set; }
    [Parameter] public string? Specialization { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public object? Doctor { get; set; } // kept for interface compat
}
