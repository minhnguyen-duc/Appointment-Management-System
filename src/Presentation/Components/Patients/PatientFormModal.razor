@if (Visible)
{
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(Patient is null ? "Thêm bệnh nhân mới" : "Chỉnh sửa hồ sơ")</h5>
                    <button class="btn-close" @onclick="OnClose"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Họ và tên <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_model.FullName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                            <input class="form-control" type="tel" @bind="_model.PhoneNumber" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input class="form-control" type="email" @bind="_model.Email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ngày sinh</label>
                            <input class="form-control" type="date" @bind="_model.DateOfBirth" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">CCCD/CMND</label>
                            <input class="form-control" @bind="_model.NationalId" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Giới tính</label>
                            <select class="form-select" @bind="_model.Gender">
                                <option value="">-- Chọn --</option>
                                <option value="Male">Nam</option>
                                <option value="Female">Nữ</option>
                                <option value="Other">Khác</option>
                            </select>
                        </div>
                    </div>
                    <ErrorAlert Message="@_error" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="OnClose">Huỷ</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        Lưu
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public PatientDto? Patient { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Inject] PatientClientService PatientService { get; set; } = null!;

    private PatientFormModel _model = new();
    private bool _saving;
    private string _error = "";

    protected override void OnParametersSet()
    {
        if (Patient is not null)
            _model = new PatientFormModel { FullName = Patient.FullName, PhoneNumber = Patient.PhoneNumber, Email = Patient.Email };
    }

    private async Task Save()
    {
        _saving = true; _error = "";
        try { await PatientService.SaveAsync(Patient?.Id, _model); await OnSaved.InvokeAsync(); await OnClose.InvokeAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }
}
