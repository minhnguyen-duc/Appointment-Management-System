@page "/auth/login"
@layout EmptyLayout
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>Đăng nhập — AMS 2026</PageTitle>

<div class="auth-card">

    <div class="auth-logo">
        <div style="width:48px;height:48px;background:var(--ams-primary-bg);border-radius:12px;
                    display:flex;align-items:center;justify-content:center;margin:0 auto .75rem;">
            <i class="bi bi-hospital text-primary fs-4"></i>
        </div>
        <h4 class="mb-0">Appointment Management</h4>
        <p class="text-muted small mb-0">Hệ thống đặt lịch khám bệnh 2026</p>
    </div>

    @if (_step == Step.EnterPhone)
    {
        <EnterPhoneForm OnSubmit="RequestOtp" IsLoading="_loading" />
    }
    else
    {
        <VerifyOtpForm @ref="_verifyForm"
                       PhoneNumber="@_phone"
                       OnSubmit="VerifyOtp"
                       OnResend="ResendOtp"
                       IsLoading="_loading"
                       ResendUsed="_resendUsed"
                       IsLocked="_locked"
                       LockedUntil="_lockedUntil" />

        <div class="text-center mt-2">
            <button class="btn btn-link btn-sm text-muted p-0" @onclick="BackToPhone">
                <i class="bi bi-arrow-left me-1"></i>Đổi số điện thoại
            </button>
        </div>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger mt-3 py-2 px-3 small mb-0 d-flex align-items-center gap-2">
            <i class="bi bi-exclamation-circle-fill"></i>
            <span>@_error</span>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private Step _step = Step.EnterPhone;
    private string _phone = "";
    private bool _loading, _locked;
    private string _error = "";
    private int _resendUsed;
    private DateTime? _lockedUntil;
    private VerifyOtpForm? _verifyForm;

    private async Task RequestOtp(string phone)
    {
        _loading = true; _error = "";
        try
        {
            await AuthService.RequestOtpAsync(phone);
            _phone = phone; _step = Step.VerifyOtp; _resendUsed = 0; _locked = false;
        }
        catch (Domain.Exceptions.OtpRateLimitExceededException ex)
        {
            _locked = true; _lockedUntil = ex.UnlockedAt; _error = ex.Message;
        }
        catch (ArgumentException ex) { _error = ex.Message; }
        catch (Exception ex)         { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task ResendOtp()
    {
        _loading = true; _error = "";
        try
        {
            await AuthService.RequestOtpAsync(_phone);
            var s = await AuthService.GetResendStatusAsync(_phone);
            _resendUsed = s.Used; _locked = false;
            _verifyForm?.ClearError();
        }
        catch (Domain.Exceptions.OtpRateLimitExceededException ex)
        {
            _locked = true; _lockedUntil = ex.UnlockedAt; _resendUsed = ex.MaxAttempts; _error = ex.Message;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task VerifyOtp(string otp)
    {
        _loading = true; _error = "";
        try
        {
            var result = await AuthService.VerifyOtpAsync(_phone, otp);
            Nav.NavigateTo(ReturnUrl ?? result.RedirectUrl);
        }
        catch (Exception ex) { _error = ex.Message; _verifyForm?.SetError(ex.Message); }
        finally { _loading = false; }
    }

    private void BackToPhone()
    {
        _step = Step.EnterPhone; _error = ""; _locked = false; _resendUsed = 0;
    }

    private enum Step { EnterPhone, VerifyOtp }
}
