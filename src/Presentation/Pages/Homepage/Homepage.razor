@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool   _isLoggedIn   = false;
    private string _userName     = "";
    private string _userInitials = "";
    private bool   _dropdownOpen = false;
    private bool   mobileNavOpen = false;
    private bool   _toastChecked = false;

    private ToastNotification? _toast;
    private ElementReference   _dropdownRef;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            var user  = state.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                _isLoggedIn = true;
                _userName = user.FindFirst("FullName")?.Value
                         ?? user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                         ?? "Người dùng";
                _userInitials = BuildInitials(_userName);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _toastChecked) return;
        _toastChecked = true;

        // Read ?t= directly from window.location.search (reliable in all render modes).
        // amsConsumeToastParam() also calls history.replaceState to clean the URL.
        var toast = await JS.InvokeAsync<string?>("amsConsumeToastParam");
        if (!string.IsNullOrEmpty(toast))
            await JS.InvokeVoidAsync("amsShowToast", toast, "info");
    }

    // ── User button / dropdown ──────────────────────────────────────────────
    private void ToggleDropdown() => _dropdownOpen = !_dropdownOpen;
    private void CloseDropdown()  => _dropdownOpen = false;

    private void GoToProfile()       { _dropdownOpen = false; Nav.NavigateTo("/benhnhan/profile"); }
    private void GoToPhieuKham()     { _dropdownOpen = false; Nav.NavigateTo("/benhnhan/phieu-kham"); }
    private void GoToNotifications() { _dropdownOpen = false; Nav.NavigateTo("/benhnhan/thong-bao"); }

    private async Task Logout()
    {
        _dropdownOpen = false;
        // Use window.location.href via JS — bypasses Blazor enhanced navigation
        // which intercepts <a href> clicks and silently swallows non-Blazor routes.
        // This is the only reliable way to navigate to a server endpoint from Blazor Server.
        await JS.InvokeVoidAsync("amsNavigate", "/auth/do-logout");
    }

    private void GoToLogin() => Nav.NavigateTo("/auth/login");

    // ── Nav helpers ─────────────────────────────────────────────────────────
    private void ToggleNav() => mobileNavOpen = !mobileNavOpen;
    private void BookDoctor() => Nav.NavigateTo("/doctors");
    private void BookByDate() => Nav.NavigateTo("/booking");

    // ── Helpers ─────────────────────────────────────────────────────────────
    private static string BuildInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        // If name looks like a phone number → use first digit
        if (name.StartsWith("0") && name.Length >= 9) return name[..1].ToUpper();
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name[..Math.Min(2, name.Length)].ToUpper();
    }
}
