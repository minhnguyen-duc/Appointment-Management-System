@page "/"
@page "/homepage"
@page "/homepage/homepage"
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Trang chủ bệnh nhân — MediCare</PageTitle>

<div class="topbar">
    <button class="hamburger" id="menuBtn" @onclick="ToggleNav" aria-label="Menu">
        <span></span><span></span><span></span>
    </button>

    <div class="logo-group">
        <div class="logo-mark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0C447C" stroke-width="2.5" stroke-linecap="round"><path d="M12 6v12M6 12h12"/></svg>
        </div>
        <span class="logo-text">MediCare</span>
    </div>

    <nav class="topbar-nav">
        <span class="nav-lnk active">Trang chủ</span>
        <span class="nav-lnk">Đặt lịch</span>
        <span class="nav-lnk">Bác sĩ</span>
        <span class="nav-lnk">Tư vấn AI</span>
        <span class="nav-lnk">Lịch sử</span>
        <span class="nav-lnk">Phiếu khám</span>
    </nav>

    <div class="topbar-spacer"></div>

    <div class="topbar-actions">
        @if (_isLoggedIn)
        {
            <!-- Logged-in: user button with dropdown -->
            <div class="user-dropdown-wrap" @ref="_dropdownRef">
                <button class="user-btn" @onclick="ToggleDropdown" type="button">
                    <div class="user-btn-av">@_userInitials</div>
                    @_userName
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="opacity:.7"><path d="m6 9 6 6 6-6"/></svg>
                </button>

                @if (_dropdownOpen)
                {
                    <div class="user-dropdown">
                        <!-- Header -->
                        <div class="dd-header">
                            <div class="dd-av">@_userInitials</div>
                            <div>
                                <div class="dd-greet">Xin chào,</div>
                                <div class="dd-name">@_userName</div>
                            </div>
                        </div>

                        <!-- Menu items -->
                        <button class="dd-item" type="button" @onclick="GoToProfile">
                            <div class="dd-item-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#185FA5" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18M8 2v4M16 2v4M9 16h6M9 12h6"/></svg>
                            </div>
                            Hồ sơ bệnh nhân
                        </button>

                        <button class="dd-item" type="button" @onclick="GoToPhieuKham">
                            <div class="dd-item-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#185FA5" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>
                            </div>
                            Phiếu khám bệnh
                        </button>

                        <button class="dd-item" type="button" @onclick="GoToNotifications">
                            <div class="dd-item-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#185FA5" stroke-width="2" stroke-linecap="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                            </div>
                            Thông báo
                        </button>

                        <div class="dd-divider"></div>

                        <button class="dd-item danger" type="button" @onclick="Logout">
                            <div class="dd-item-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2" stroke-linecap="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                            </div>
                            Đăng xuất
                        </button>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Logged-out: Tài khoản button -->
            <button class="account-btn" type="button" @onclick="GoToLogin">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Tài khoản
            </button>
        }
    </div>
</div>

<!-- Mobile nav drawer -->
<nav class="mobile-nav @(mobileNavOpen ? "open" : "")" id="mobileNav">
    <span class="mob-nav-lnk active">Trang chủ</span>
    <span class="mob-nav-lnk">Đặt lịch</span>
    <span class="mob-nav-lnk">Bác sĩ</span>
    <span class="mob-nav-lnk">Tư vấn AI</span>
    <span class="mob-nav-lnk">Lịch sử khám</span>
    <span class="mob-nav-lnk">Phiếu khám</span>
</nav>

<!-- Click-outside overlay for dropdown -->
@if (_dropdownOpen)
{
    <div style="position:fixed;inset:0;z-index:199;" @onclick="CloseDropdown"></div>
}

<ToastNotification @ref="_toast" />

