<div class="doc-row" role="button" tabindex="0" @onclick="HandleClick">
    <div class="doc-av-wrap">
        <div class="doc-av" style="@($"background:{Avatar}")">@Initials</div>
        @if (IsOnline)
        {
            <div class="doc-online"></div>
        }
    </div>
    <div class="doc-info">
        <div class="doc-name">@Name</div>
        <div class="doc-spec">@Specialty</div>
        <div class="doc-rating"><span class="star">★</span> @Rating · @ReviewCount đánh giá</div>
    </div>
    <button class="book-btn" @onclick:stopPropagation="true" @onclick="HandleBooking">Đặt lịch</button>
</div>

@code {
    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? Specialty { get; set; }

    [Parameter]
    public string? Rating { get; set; }

    [Parameter]
    public string? ReviewCount { get; set; }

    [Parameter]
    public string? Initials { get; set; }

    [Parameter]
    public string? Avatar { get; set; }

    [Parameter]
    public bool IsOnline { get; set; }

    private void HandleClick()
    {
        // Navigate to doctor profile
    }

    private void HandleBooking()
    {
        // Handle booking action
    }
}
