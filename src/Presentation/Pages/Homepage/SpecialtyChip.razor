<div class="spec-chip" tabindex="0" @onclick="HandleClick">
    <div class="spec-icon-wrap" style="@($"background:{BgColor}")">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="@TextColor" stroke-width="2" stroke-linecap="round">
            <path d="@Icon"/>
        </svg>
    </div>
    <div class="spec-name">@Name</div>
    <div class="spec-cnt">@Count</div>
</div>

@code {
    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? Count { get; set; }

    [Parameter]
    public string? BgColor { get; set; }

    [Parameter]
    public string? TextColor { get; set; }

    [Parameter]
    public string? Icon { get; set; }

    private void HandleClick()
    {
        // Handle specialty selection
    }
}
