@page "/benhnhan/dashboard"
@page "/benhnhan"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject NavigationManager Nav
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContext

<PageTitle>Trang chủ bệnh nhân — MediCare</PageTitle>

@* KAN-34: Serve patient homepage designed in KAN-31 (patient-homepage.html)
   The page is a static HTML asset in wwwroot — redirect to it so the full
   CSS/JS/font pipeline of the designed code runs in the browser natively. *@

@code {
    protected override void OnInitialized()
    {
        // Navigate to the patient homepage designed in KAN-31
        // forceLoad=true exits the Blazor SPA circuit and serves the static HTML
        Nav.NavigateTo("/patient-homepage.html", forceLoad: true);
    }
}
